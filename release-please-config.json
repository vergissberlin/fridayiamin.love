{
  "packages": {
    ".": {
      "changelog-path": "CHANGELOG.md",
      "release-type": "node",
      "draft": false,
      "prerelease": false,
      "versioning-strategy": "always-bump-patch"
    }
  },
  "commit-search-depth": 100,
  "group-pull-request-check-options": {
    "skip-labeling": true,
    "skip-release": true
  }
}
